{
  "info": {
    "name": "SortMyScene Auth API",
    "_postman_id": "sortmyscene-auth-v1",
    "description": "Complete auth flow: register → login → /me → refresh → logout → verify",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('success true', () => pm.expect(body.success).to.be.true);",
              "pm.collectionVariables.set('accessToken',  body.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
              "pm.test('accessToken set',  () => pm.expect(body.data.accessToken).to.be.a('string'));",
              "pm.test('refreshToken set', () => pm.expect(body.data.refreshToken).to.be.a('string'));",
              "pm.test('no passwordHash',  () => pm.expect(JSON.stringify(body)).to.not.include('passwordHash'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1\"\n}"
        }
      }
    },
    {
      "name": "2. Register — Duplicate Email (expect 409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 409 conflict', () => pm.response.to.have.status(409));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1\"\n}"
        }
      }
    },
    {
      "name": "3. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('accessToken',  body.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
              "pm.test('no passwordHash', () => pm.expect(JSON.stringify(body)).to.not.include('passwordHash'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1\"\n}"
        }
      }
    },
    {
      "name": "4. Login — Wrong Password (expect 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "const body = pm.response.json();",
              "pm.test('Generic message', () => pm.expect(body.message).to.equal('Invalid credentials'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"WrongPassword\"\n}"
        }
      }
    },
    {
      "name": "5. GET /me",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('user returned', () => pm.expect(body.data.user).to.be.an('object'));",
              "pm.test('no passwordHash', () => pm.expect(JSON.stringify(body)).to.not.include('passwordHash'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "6. GET /me — No Token (expect 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "7. Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('new accessToken', () => pm.expect(body.data.accessToken).to.be.a('string'));",
              "pm.test('new refreshToken', () => pm.expect(body.data.refreshToken).to.be.a('string'));",
              "// Store new tokens",
              "pm.collectionVariables.set('accessToken',  body.data.accessToken);",
              "const oldRefresh = pm.collectionVariables.get('refreshToken');",
              "pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
              "pm.collectionVariables.set('oldRefreshToken', oldRefresh);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "8. Refresh Token Reuse (expect 401 — session compromised)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "const body = pm.response.json();",
              "pm.test('Session compromised message', () => pm.expect(body.message).to.include('compromised'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{oldRefreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "9. Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('success', () => pm.expect(body.success).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/auth/logout",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "10. GET /me after Logout — Token still valid (access tokens are stateless)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Access tokens are stateless JWTs, still valid until expiry",
              "// Use refresh token to verify session is terminated",
              "pm.test('Status 200 (access token still valid until expiry)', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "11. Refresh after Logout — Token revoked (expect 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 — refresh token revoked after logout', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "12. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
