{
  "info": {
    "name": "SortMyScene Bookings API",
    "_postman_id": "sortmyscene-bookings-v1",
    "description": "API collection for testing private booking endpoints in SortMyScene booking platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Confirm booking (Success)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response format is valid success payload\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.success).to.be.true;",
              "    pm.expect(response.data).to.have.property(\"bookingId\");",
              "    pm.expect(response.data).to.have.property(\"bookingReference\");",
              "    pm.expect(response.data.bookingReference).to.match(/^SMS-\\d{4}-\\d{6}$/);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"{{reservation_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Confirms an active reservation, transitions reserved seats to BOOKED, and issues a booking reference."
      },
      "response": []
    },
    {
      "name": "2. Confirm booking - Invalid reservationId (400 Bad Request)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test(\"Response returns validation error\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.success).to.be.false;",
              "    pm.expect(response.message).to.eql(\"Validation failed\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"invalid-id\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Asserts that sending a structurally invalid reservation ID format triggers Joi validation errors."
      },
      "response": []
    },
    {
      "name": "3. Confirm booking - Missing Auth Token (401 Unauthorized)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401\", function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"{{reservation_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Asserts that requesting booking confirmation without an authorization header fails with 401 Unauthorized."
      },
      "response": []
    },
    {
      "name": "4. Confirm booking - Reservation belongs to another user (403 Forbidden)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 403\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "",
              "pm.test(\"Response returns forbidden message\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.success).to.be.false;",
              "    pm.expect(response.message).to.eql(\"Reservation does not belong to current user\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{other_user_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"{{reservation_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Asserts that requesting booking confirmation for a reservation belonging to another user returns 403 Forbidden."
      },
      "response": []
    },
    {
      "name": "5. Confirm booking - Reservation already completed (409 Conflict)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 409\", function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test(\"Response returns conflict message\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.success).to.be.false;",
              "    pm.expect(response.message).to.eql(\"Reservation already confirmed\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"{{completed_reservation_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Asserts that confirming an already completed reservation fails with 409 Conflict."
      },
      "response": []
    },
    {
      "name": "6. Confirm booking - Reservation expired (410 Gone)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 410\", function () {",
              "    pm.response.to.have.status(410);",
              "});",
              "",
              "pm.test(\"Response returns gone message\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.success).to.be.false;",
              "    pm.expect(response.message).to.eql(\"Reservation expired\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reservationId\": \"{{expired_reservation_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/bookings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        },
        "description": "Asserts that confirming an expired reservation fails with 410 Gone."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "other_user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "reservation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "completed_reservation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "expired_reservation_id",
      "value": "",
      "type": "string"
    }
  ]
}
